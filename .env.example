# GitHub will redirect here after login (use your domain accordingly)
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback

# Base URL for your API (change to your domain accordingly)
API_BASE_URL=http://localhost:3000

# GitHub OAuth app Client ID (from GitHub Developer settings)
GITHUB_CLIENT_ID=your_github_client_id

# GitHub OAuth app Client Secret (from GitHub Developer settings)
GITHUB_CLIENT_SECRET=your_github_client_secret

# Port for the server (default: 3000)
PORT=3000
